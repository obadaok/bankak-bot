# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/bankak-bot?retryWrites=true&w=majority

# Admin WhatsApp number (the number the bot will use)
# Format: full international number without + or spaces
# Example: 966501234567
ADMIN_NUMBER=966XXXXXXXXX

# Admin token for protecting /reset-auth and /qr.png endpoints (required for security)
ADMIN_TOKEN=choose-a-strong-random-token

# Port for the Express web server (keep-alive)
PORT=3000

# Session timeout in milliseconds (default: 60000 = 1 minute)
SESSION_TIMEOUT=60000
